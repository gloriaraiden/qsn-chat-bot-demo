# Instagram Graph API – page access token with instagram_manage_messages permission
IG_ACCESS_TOKEN=""

# Arbitrary string you set when subscribing the webhook in Meta App Dashboard
VERIFY_TOKEN=""
# Google Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# The specific Instagram group-chat thread ID the bot should respond in.
# Set to FIND_ME (or leave empty) to activate Discovery Mode — the bot will
# log every incoming thread ID to the console so you can copy it.
TARGET_THREAD_ID=FIND_ME

# The bot's Instagram username (without leading @)
BOT_USERNAME=your_bot_username

# Global cooldown between Gemini responses, in seconds (default: 300 = 5 min)
COOLDOWN_SECONDS=300
